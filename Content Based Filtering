    "movies['year'] = movies['release date'].apply(lambda x: str(x).split('-')[-1])\n",
    "genres_cols = ['Action' , 'Adventure' , 'Animation' ,\n",
    "            \"Children's\" , 'Comedy' , 'Crime' , 'Documentary' , 'Drama' , 'Fantasy' ,\n",
    "              'Film-Noir' , 'Horror' , 'Musical' , 'Mystery' , 'Romance' , 'Sci-Fi' ,\n",
    "              'Thriller' , 'War' , 'Western']\n",
    "genres_dict = {col: 'sum' for col in genres_cols}\n",
    "genres = movies.groupby(['year'],as_index=False).agg(genres_dict)\n",
    "genres = genres.sort_values('year')\n",
    "print(genres['year'].unique()) # could see there is 'nan'\n",
    "\n",
    "genres['year'] = genres['year'].replace(['Nan','nan','',' '],np.nan)\n",
    "genres = genres.dropna(subset=['year'])\n",
    "genres"
   ]
